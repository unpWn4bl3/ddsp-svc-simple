{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--headless=true",
        "--proxy-server=socks5://localhost:2340"
      ]
    },
  },
  "permission": {
    "*": "allow"
  }
}
